{
  "name": "momo_py",
  "version": "0.1.1",
  "description": "An Electron application with Vue",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "sync:meta": "node scripts/sync-package-meta.mjs",
    "prebuild": "node scripts/sync-package-meta.mjs",
    "prebuild:python": "node scripts/sync-package-meta.mjs",
    "build:python": "node scripts/build-python.mjs",
    "build:unpack": "npm run build && electron-builder --dir --config electron-builder.config.js",
    "build:win": "npm run build:python && npm run build && electron-builder --win --config electron-builder.config.js",
    "build:mac": "npm run build:python && npm run build && electron-builder --mac --config electron-builder.config.js",
    "build:linux": "npm run build:python && npm run build && electron-builder --linux --config electron-builder.config.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.3.9",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "lottie-web": "^5.13.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "prettier": "^3.7.4",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-router": "^4.6.4"
  }
}
